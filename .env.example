# Copiar este archivo a `.env` (sin .example) y ajustar.
# ------------------------------------------------------

# Ruta a la base SQLite donde la app guarda tus transacciones.
DB_PATH=./data/finanzas.db

# Ruta al CSV de transacciones diarias (sólo se usa en la importación inicial).
DIARIO_CSV=./Diario.csv

# Ruta al CSV mensual con previsión vs realidad (sólo se usa en la importación inicial).
MENSUAL_CSV=./Mensual.csv

# Saldo del fondo de emergencia en USD. Por ahora informativo; se muestra en el dashboard.
FONDO_EMERGENCIA_USD=864

# Cantidad de copias de backup a retener.
BACKUP_RETENTION=30

# --- Seguridad (premortem #3) ---

# Código de invitación para crear cuentas nuevas. Si NO está definido,
# el signup queda deshabilitado (solo login). En Fly:
#   fly secrets set SIGNUP_CODE=elegir-un-codigo
# SIGNUP_CODE=

# Secret para los tokens de sesión "recordarme" (evita re-login en cada
# refresh). Si NO está definido, la sesión funciona como siempre (solo
# st.session_state). Generar con: openssl rand -hex 32. En Fly:
#   fly secrets set SESSION_SECRET=<valor>
# Rotarlo invalida todas las sesiones recordadas.
# SESSION_SECRET=
